FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /mock-backend ./cmd/mock-backend

FROM alpine:3.20
WORKDIR /app
COPY --from=builder /mock-backend .
EXPOSE 8081
ENTRYPOINT ["/app/mock-backend"]
